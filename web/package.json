{
	"name": "web",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@lucide/vue": "^1.14.0",
		"@tailwindcss/vite": "^4.3.0",
		"tailwindcss": "^4.3.0",
		"vue": "^3.5.34",
		"vue-sonner": "^2.0.9"
	},
	"devDependencies": {
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^24.12.3",
		"@vitejs/plugin-vue": "^6.0.6",
		"@vue/tsconfig": "^0.9.1",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.12",
		"vite-plugin-singlefile": "^2.3.3",
		"vue-tsc": "^3.2.8"
	},
	"prettier": {
		"semi": false,
		"singleQuote": true,
		"printWidth": 144,
		"useTabs": true,
		"importOrder": [
			"<BUILTIN_MODULES>",
			"<THIRD_PARTY_MODULES>",
			"^@/",
			"^\\./"
		],
		"importOrderSeparation": false,
		"plugins": [
			"prettier-plugin-tailwindcss",
			"@trivago/prettier-plugin-sort-imports"
		]
	}
}
